# ══════════════════════════════════════════════
#  AutoTouch Android Project .gitignore
# ══════════════════════════════════════════════

# ── Gradle ──
.gradle/
build/
**/build/

# ── Android Studio / IntelliJ IDEA ──
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/

# ── Local configuration ──
local.properties
*.local

# ── Signing ──
*.jks
*.keystore
signing.properties

# ── APK / AAB / Bundle ──
*.apk
*.aab
*.ap_
*.dex

# ── Kotlin ──
*.kotlin_module

# ── Native ──
*.so
obj/

# ── Log files ──
*.log

# ── OS generated ──
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
._*

# ── Crash reports ──
crash-report-*.txt

# ── Proguard ──
proguard/

# ── Misc ──
*.hprof
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
